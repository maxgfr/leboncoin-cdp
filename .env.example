# Browser Configuration
CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
HEADLESS=false
PAGE_TIMEOUT=30000

# Scraping Configuration
MAX_RETRIES=5
RATE_LIMIT=1000
MAX_PAGES=

# Output Configuration
OUTPUT_DIR=./assets
SAVE_RAW=false

# Advanced
# Override the scraper data dir (profile + saved CDP port). Default: ~/.lbc-scraper
# LBC_SCRAPER_HOME=
