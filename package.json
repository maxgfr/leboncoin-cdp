{
  "name": "leboncoin",
  "version": "1.0.0",
  "author": "maxgfr",
  "license": "MIT",
  "type": "module",
  "description": "Leboncoin fetcher",
  "main": "./build/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxgfr/leboncoin.git"
  },
  "bugs": {
    "url": "https://github.com/maxgfr/leboncoin/issues"
  },
  "homepage": "https://github.com/maxgfr/leboncoin#readme",
  "files": [
    "build"
  ],
  "keywords": [
    "leboncoin"
  ],
  "scripts": {
    "start": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" node build/index.js",
    "dev": "nodemon",
    "develop": "swc ./src -d build && NODE_OPTIONS=\"--experimental-specifier-resolution=node\" node build/index.js",
    "test": "DOTENV_CONFIG_PATH=.env.test jest",
    "test:watch": "DOTENV_CONFIG_PATH=.env.test jest --watch",
    "clean": "rimraf build",
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -w -p tsconfig.json",
    "build:swc": "swc ./src -d build",
    "build:swc:watch": "swc ./src -d build -w",
    "lint": "eslint ./src --ext .ts",
    "prettier": "prettier --write './src/**/*.{ts,js,json}'"
  },
  "dependencies": {
    "apify": "^2.2.2",
    "dotenv": "16.0.0",
    "puppeteer": "^13.5.1"
  },
  "devDependencies": {
    "@swc/cli": "0.1.56",
    "@swc/core": "1.2.160",
    "@swc/jest": "0.2.20",
    "@types/cookie": "^0.4.1",
    "@types/jest": "27.4.1",
    "@types/node": "16.11.26",
    "@types/user-agents": "^1.0.2",
    "@typescript-eslint/eslint-plugin": "5.16.0",
    "@typescript-eslint/parser": "5.16.0",
    "eslint": "8.11.0",
    "eslint-config-prettier": "8.5.0",
    "eslint-plugin-jest": "26.1.2",
    "jest": "27.5.1",
    "nodemon": "2.0.15",
    "prettier": "2.6.0",
    "rimraf": "3.0.2",
    "typescript": "4.6.2"
  },
  "engines": {
    "node": "16.x"
  }
}
