{
  "name": "leboncoin",
  "version": "1.0.0",
  "author": "maxgfr",
  "license": "MIT",
  "description": "Leboncoin fetcher",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxgfr/leboncoin.git"
  },
  "bugs": {
    "url": "https://github.com/maxgfr/leboncoin/issues"
  },
  "homepage": "https://github.com/maxgfr/leboncoin#readme",
  "files": [
    "build"
  ],
  "keywords": [
    "leboncoin"
  ],
  "scripts": {
    "start": "node build/index.js",
    "dev": "nodemon",
    "develop": "swc ./src -d build && node build/index.js",
    "test": "vitest",
    "clean": "rimraf build",
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -w -p tsconfig.json",
    "build:swc": "swc ./src -d build",
    "build:swc:watch": "swc ./src -d build -w",
    "lint": "eslint ./src --ext .ts",
    "prettier": "prettier --write './src/**/*.{ts,js,json}'"
  },
  "dependencies": {
    "puppeteer": "^21.7.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-adblocker": "^2.13.6",
    "puppeteer-extra-plugin-anonymize-ua": "^2.4.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "@swc/cli": "0.1.60",
    "@swc/core": "1.3.32",
    "@types/cookie": "0.5.1",
    "@types/node": "18.11.18",
    "@types/user-agents": "1.0.2",
    "@typescript-eslint/eslint-plugin": "5.50.0",
    "@typescript-eslint/parser": "5.50.0",
    "eslint": "8.33.0",
    "eslint-config-prettier": "8.6.0",
    "nodemon": "2.0.20",
    "prettier": "2.8.3",
    "rimraf": "4.1.2",
    "typescript": "4.9.5",
    "vitest": "^1.2.0"
  }
}
