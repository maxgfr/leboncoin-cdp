{
  "name": "leboncoin",
  "version": "1.0.0",
  "author": "maxgfr",
  "license": "MIT",
  "description": "Leboncoin fetcher",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxgfr/leboncoin.git"
  },
  "bugs": {
    "url": "https://github.com/maxgfr/leboncoin/issues"
  },
  "homepage": "https://github.com/maxgfr/leboncoin#readme",
  "files": [
    "build"
  ],
  "keywords": [
    "leboncoin"
  ],
  "scripts": {
    "start": "node build/index.js",
    "dev": "nodemon",
    "develop": "mkdirp assets && swc ./src -d build && node build/index.js",
    "test": "mkdirp assets && vitest",
    "clean": "rimraf build",
    "build": "mkdirp assets && tsc -p tsconfig.json",
    "build:watch": "tsc -w -p tsconfig.json",
    "build:swc": "mkdirp assets && swc ./src -d build",
    "build:swc:watch": "swc ./src -d build -w",
    "lint": "eslint ./src --ext .ts",
    "prettier": "prettier --write './src/**/*.{ts,js,json}'"
  },
  "dependencies": {
    "puppeteer": "^24.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-adblocker": "^2.13.6",
    "puppeteer-extra-plugin-anonymize-ua": "^2.4.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "@swc/cli": "0.1.60",
    "@swc/core": "1.3.32",
    "@types/cookie": "1.0.0",
    "@types/node": "24.10.4",
    "@types/user-agents": "1.0.2",
    "@typescript-eslint/eslint-plugin": "8.49.0",
    "@typescript-eslint/parser": "8.49.0",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "mkdirp": "^3.0.1",
    "nodemon": "3.1.11",
    "prettier": "3.7.4",
    "rimraf": "6.1.2",
    "typescript": "5.9.3",
    "vitest": "^1.2.0"
  }
}
