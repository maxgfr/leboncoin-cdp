{
  "name": "leboncoin-cdp-scraper",
  "version": "2.0.0",
  "author": "maxgfr",
  "license": "MIT",
  "description": "Leboncoin scraper using CDP + in-page fetch (zero bot detection)",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxgfr/leboncoin-cdp-scraper.git"
  },
  "bugs": {
    "url": "https://github.com/maxgfr/leboncoin-cdp-scraper/issues"
  },
  "homepage": "https://github.com/maxgfr/leboncoin-cdp-scraper#readme",
  "packageManager": "pnpm@10",
  "files": [
    "build"
  ],
  "keywords": [
    "leboncoin",
    "scraper",
    "cdp",
    "chrome-devtools-protocol"
  ],
  "scripts": {
    "start": "rm -rf build && pnpm build:swc && node build/index.js",
    "dev": "nodemon",
    "develop": "mkdirp assets && swc src -d build --strip-leading-paths && node build/index.js",
    "test": "mkdirp assets && vitest",
    "clean": "rimraf build",
    "build": "mkdirp assets && tsc -p tsconfig.json",
    "build:watch": "tsc -w -p tsconfig.json",
    "build:swc": "mkdirp assets && swc src -d build --strip-leading-paths",
    "build:swc:watch": "swc src -d build --strip-leading-paths -w",
    "lint": "eslint src/",
    "format": "prettier --write './src/**/*.{ts,js,json}'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@swc/cli": "^0.5.2",
    "@swc/core": "^1.15.11",
    "@types/node": "^22.19.9",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "mkdirp": "^3.0.1",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^2.1.9"
  }
}
