{
  "name": "leboncoin",
  "version": "1.0.0",
  "author": "maxgfr",
  "license": "MIT",
  "type": "module",
  "description": "Leboncoin fetcher",
  "main": "./build/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxgfr/leboncoin.git"
  },
  "bugs": {
    "url": "https://github.com/maxgfr/leboncoin/issues"
  },
  "homepage": "https://github.com/maxgfr/leboncoin#readme",
  "files": [
    "build"
  ],
  "keywords": [
    "leboncoin"
  ],
  "scripts": {
    "start": "NODE_OPTIONS=\"--experimental-specifier-resolution=node\" node build/index.js",
    "dev": "nodemon",
    "develop": "swc ./src -d build && NODE_OPTIONS=\"--experimental-specifier-resolution=node\" node build/index.js",
    "test": "DOTENV_CONFIG_PATH=.env.test jest --passWithNoTests",
    "test:watch": "DOTENV_CONFIG_PATH=.env.test jest --watch --passWithNoTests",
    "clean": "rimraf build",
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -w -p tsconfig.json",
    "build:swc": "swc ./src -d build",
    "build:swc:watch": "swc ./src -d build -w",
    "lint": "eslint ./src --ext .ts",
    "prettier": "prettier --write './src/**/*.{ts,js,json}'"
  },
  "dependencies": {
    "puppeteer": "^19.0.0",
    "puppeteer-extra": "^3.2.3",
    "puppeteer-extra-plugin-adblocker": "^2.12.0",
    "puppeteer-extra-plugin-anonymize-ua": "^2.3.3",
    "puppeteer-extra-plugin-stealth": "^2.9.0"
  },
  "devDependencies": {
    "@swc/cli": "0.1.57",
    "@swc/core": "1.3.21",
    "@swc/jest": "0.2.23",
    "@types/cookie": "0.5.1",
    "@types/jest": "29.2.3",
    "@types/node": "18.11.10",
    "@types/user-agents": "1.0.2",
    "@typescript-eslint/eslint-plugin": "5.45.0",
    "@typescript-eslint/parser": "5.45.0",
    "eslint": "8.29.0",
    "eslint-config-prettier": "8.5.0",
    "eslint-plugin-jest": "27.1.6",
    "jest": "29.3.1",
    "nodemon": "2.0.20",
    "prettier": "2.8.0",
    "rimraf": "3.0.2",
    "typescript": "4.9.3"
  },
  "engines": {
    "node": "16.x"
  }
}
